# Monorepo Settings
NODE_ENV=development

# Frontend (apps/web)
VITE_API_URL=http://localhost:8000/api/v1

# Backend API (services/backend-api)
PORT=8000
# Usado por services/backend-api/src/config/database.js (pool pg) y por
# database/ (node-pg-migrate y seeds). En local apunta al Postgres de
# docker-compose; en Render/producción se configura con la connection
# string real de Neon (ver database/README.md).
DATABASE_URL=postgresql://safeplace_user:safeplace_password@postgres:5432/safeplace_db
JWT_SECRET=super_secret_jwt_key_for_development
JWT_EXPIRES_IN=1d
DEVICE_TOKEN_SECRET=super_secret_device_token_key

# Gateway BLE (services/gateway-ble)
BACKEND_URL=http://localhost:8000/api/v1
GATEWAY_ID=gw-pi-001
GATEWAY_TOKEN=your_device_token_here
SCAN_INTERVAL_MS=5000
RETRY_MAX_ATTEMPTS=5

# PostgreSQL (database)
POSTGRES_USER=safeplace_user
POSTGRES_PASSWORD=safeplace_password
POSTGRES_DB=safeplace_db

# Ingesta de mediciones (Servicio de Validación de Datos, RF-04/H0008)
# API key con la que el gateway se autentica en POST /api/v1/mediciones
# (middleware deviceAuth, header x-device-api-key)
GATEWAY_API_KEY=super_secret_gateway_api_key
# TTL del flag de consentimiento en caché (RNF-09), en milisegundos
CONSENTIMIENTO_CACHE_TTL_MS=30000
